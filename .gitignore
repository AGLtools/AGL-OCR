__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual env
.venv/
venv/
env/

# PyInstaller
packaging/build/
dist/

# OCR cache (large PNG files, regenerated automatically)
data/cache/

# User exports (generated output, not source)
data/exports/

# Bundled binaries — large, OS-specific, downloaded separately (see README)
poppler/
tesseract/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Logs
*.log

# Build / deployment artefacts (heavy, regenerated by Forcompilation\BUILD_ALL.bat)
Forcompilation/python_portable/
Forcompilation/desktop_launcher/build/
Forcompilation/desktop_launcher/dist/
Forcompilation/desktop_launcher/*.spec
Forcompilation/installer/wheelhouse/
Forcompilation/installer/dist/
Forcompilation/dist/
.current_version

# User-generated corrections (per-document sidecar files, machine-specific)
data/corrections/

# User templates (created in-app at runtime, not source code)
data/templates/*.json

# AI configuration (contains API key — NEVER commit)
data/ai_config.json

# AI-learned formats (per-installation, may contain sensitive carrier hints)
data/learned_formats/

# Test / diagnostic artefacts (not part of the deployable app)
testing_pdf/
